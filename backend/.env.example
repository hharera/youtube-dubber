 # Copy to .env (or just export these before `npm start`)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides
PORT=3000
GEMINI_MODEL=gemini-flash-lite-latest
SUPERTONIC_URL=http://127.0.0.1:7788
# Captions are fetched with yt-dlp. By default the backend uses ../.venv/bin/yt-dlp,
# falling back to `yt-dlp` on PATH. Override the path here if needed.
YTDLP_PATH=

# If YouTube returns HTTP 429 (Too Many Requests) on caption downloads, reuse your
# browser's logged-in YouTube cookies. Set to your browser name: brave, chrome,
# firefox, safari, or edge. Leave blank to disable.
YTDLP_COOKIES_FROM_BROWSER=
